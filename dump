<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gabriel | Nursing & Notes</title>
    <style>
        :root {
            --sage-deep: #4a5d45;
            --sage-light: #87a982;
            --glass: rgba(255, 255, 255, 0.12);
            --text: #ffffff;
        }

        body, html {
            margin: 0; padding: 0; height: 100%;
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #3a4737 0%, #87a982 100%);
            color: var(--text);
            overflow-x: hidden;
        }

        .wrapper {
            display: flex;
            height: 100vh;
            width: 100vw;
            padding: 40px;
            box-sizing: border-box;
            gap: 25px;
            overflow-x: auto;
            align-items: center;
        }

        .panel {
            min-width: 400px;
            height: 85vh;
            background: var(--glass);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 40px;
            padding: 40px;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
        }

        /* Profile & About */
        .profile-img {
            width: 150px; height: 150px;
            border-radius: 50%;
            border: 3px solid white;
            margin-bottom: 20px;
            object-fit: cover;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 15px;
        }

        .stat-box {
            background: rgba(255,255,255,0.1);
            padding: 10px;
            border-radius: 12px;
            font-size: 0.8rem;
            text-align: center;
        }

        /* List & Hover */
        h2 { font-weight: 300; letter-spacing: 2px; text-transform: uppercase; border-bottom: 1px solid rgba(255,255,255,0.2); padding-bottom: 10px; }
        .list-container { overflow-y: auto; margin-top: 10px; }

        .item-row {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            padding: 15px;
            margin-bottom: 15px;
            transition: 0.3s;
            cursor: pointer;
        }

        .item-row:hover { background: white; color: var(--sage-deep); transform: translateY(-5px); }

        .card-header { display: flex; align-items: center; gap: 15px; }
        .card-header img { width: 50px; height: 50px; border-radius: 10px; object-fit: cover; }

        /* YouTube Container */
        .player-container {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.5s ease, margin-top 0.3s ease;
            width: 100%;
        }

        .item-row:hover .player-container {
            max-height: 220px;
            margin-top: 15px;
        }

        @media (max-width: 768px) {
            .wrapper { flex-direction: column; height: auto; }
            .panel { min-width: 100%; height: auto; }
        }
    </style>
</head>
<body>

<div class="wrapper">
    
    <section class="panel" style="justify-content: center; align-items: center; text-align: center;">
        <img src="https://raw.githubusercontent.com/hairooo/index/refs/heads/main/images/ooakoto.png" alt="Gabriel" class="profile-img">
        <h1 style="margin: 0;">Gabriel</h1>
        <p style="font-style: italic; opacity: 0.8;">"I think I’ve discovered that I’m a bit of a romantic."</p>
        
        <div class="stats-grid">
            <div class="stat-box"><strong>20</strong><br>Years Old</div>
            <div class="stat-box"><strong>2nd Year</strong><br>Nursing</div>
            <div class="stat-box" style="grid-column: span 2;"><strong>Bicol University</strong><br>Tabaco Campus</div>
        </div>

        <div style="margin-top: 20px; font-size: 0.85rem; text-align: left;">
            🩺 <strong>Studying:</strong> Clinicals & Med-Surg<br>
            🎬 <strong>Watching:</strong> Fleabag, Binge-worthy films<br>
            🛌 <strong>Status:</strong> Probably sleeping
        </div>
    </section>

    <section class="panel">
        <h2>Top Artists</h2>
        <div class="list-container">
            <div class="item-row"><div class="card-header"><img src="https://raw.githubusercontent.com/hairooo/index/refs/heads/main/images/Clairo.jpg"><span>Clairo</span></div></div>
            <div class="item-row"><div class="card-header"><img src="https://raw.githubusercontent.com/hairooo/index/refs/heads/main/images/CocteuTwins.jpg"><span>Cocteau Twins</span></div></div>
            <div class="item-row"><div class="card-header"><img src="https://raw.githubusercontent.com/hairooo/index/refs/heads/main/images/FleetwoodMac.jpg"><span>Fleetwood Mac</span></div></div>
            <div class="item-row"><div class="card-header"><img src="https://raw.githubusercontent.com/hairooo/index/refs/heads/main/images/WeyesBlood.jpg"><span>Weyes Blood</span></div></div>
            <div class="item-row"><div class="card-header"><img src="https://raw.githubusercontent.com/hairooo/index/refs/heads/main/images/MattMaltese.jpg"><span>Matt Maltese</span></div></div>
        </div>
    </section>

    <section class="panel">
        <h2>Top Songs</h2>
        <div class="list-container">
            
            <div class="item-row">
                <div class="card-header">
                    <img src="https://raw.githubusercontent.com/hairooo/index/refs/heads/main/images/harbor.jpg">
                    <div><strong>Harbor</strong><br><small>Clairo</small></div>
                </div>
                <div class="player-container">
                    <iframe width="100%" height="180" src="https://www.youtube.com/embed/6m6S_6B2Iaw" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
                </div>
            </div>

            <div class="item-row">
                <div class="card-header">
                    <img src="https://raw.githubusercontent.com/hairooo/index/refs/heads/main/images/rilkeanheart.jpg">
                    <div><strong>Rilkean Heart</strong><br><small>Cocteau Twins</small></div>
                </div>
                <div class="player-container">
                    <iframe width="100%" height="180" src="https://www.youtube.com/embed/7V-M7qBvG8A" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
                </div>
            </div>

            <div class="item-row">
                <div class="card-header">
                    <img src="https://raw.githubusercontent.com/hairooo/index/f8c01717babdbb0a51867d5b9086e5143328f682/images/Andromeda.jpg">
                    <div><strong>Andromeda</strong><br><small>Weyes Blood</small></div>
                </div>
                <div class="player-container">
                    <iframe width="100%" height="180" src="https://www.youtube.com/embed/Rgp_9j-N55E" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
                </div>
            </div>

        </div>
    </section>

</div>

</body>
</html>
